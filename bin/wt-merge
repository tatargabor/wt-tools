#!/usr/bin/env bash
# wt-merge - Merge a worktree branch to target branch

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/wt-common.sh"

usage() {
    cat <<EOF
Usage: wt-merge <change-id> [options]

Merge a worktree's branch into a target branch.

Arguments:
  change-id               The change identifier

Options:
  -p, --project <name>    Use specific project (default: auto-detect)
  --to <branch>           Target branch (default: auto-detect main/master)
  --squash                Squash commits into one
  --no-delete             Keep source branch after merge
  --no-push               Don't push after merge (default: push)
  --llm-resolve           Use LLM to resolve merge conflicts automatically
  -h, --help              Show this help

Examples:
  wt-merge add-user-auth
  wt-merge add-user-auth --to develop
  wt-merge add-user-auth --squash
EOF
}

# Find the default branch (main or master)
find_default_branch() {
    local project_path="$1"

    if git -C "$project_path" show-ref --verify --quiet refs/heads/main 2>/dev/null; then
        echo "main"
    elif git -C "$project_path" show-ref --verify --quiet refs/heads/master 2>/dev/null; then
        echo "master"
    else
        echo ""
    fi
}

# Patterns for generated/build files that can be safely auto-resolved on merge conflict.
# These files are regenerated by the build system, so accepting "ours" (target branch) is safe.
GENERATED_FILE_PATTERNS=(
    "tsconfig.tsbuildinfo"
    "*.tsbuildinfo"
    "package-lock.json"
    "yarn.lock"
    "pnpm-lock.yaml"
    ".next/**"
    "dist/**"
    "build/**"
)

# Check if a file matches any generated file pattern.
is_generated_file() {
    local file="$1"
    local basename
    basename=$(basename "$file")
    for pattern in "${GENERATED_FILE_PATTERNS[@]}"; do
        case "$pattern" in
            *"/**")
                # Directory prefix match
                local dir_prefix="${pattern%/**}"
                if [[ "$file" == "$dir_prefix/"* ]]; then
                    return 0
                fi
                ;;
            *"*"*)
                # Glob match on basename
                # shellcheck disable=SC2254
                if [[ "$basename" == ${pattern} ]]; then
                    return 0
                fi
                ;;
            *)
                # Exact basename match
                if [[ "$basename" == "$pattern" ]]; then
                    return 0
                fi
                ;;
        esac
    done
    return 1
}

# Try to auto-resolve merge conflicts in generated/build files.
# Accepts "ours" (target branch) for generated files — they'll be regenerated by build.
# When partial=true, resolves generated files even if non-generated conflicts remain.
# Returns 0 if all conflicts resolved, 1 if non-generated files still have conflicts.
auto_resolve_generated_files() {
    local conflicted_files="$1"
    local partial="${2:-false}"
    local generated_files=()
    local has_non_generated=false

    while IFS= read -r file; do
        [[ -z "$file" ]] && continue
        if is_generated_file "$file"; then
            generated_files+=("$file")
        else
            has_non_generated=true
        fi
    done <<< "$conflicted_files"

    # No generated files to resolve
    if [[ ${#generated_files[@]} -eq 0 ]]; then
        return 1
    fi

    # Without partial mode, only resolve if ALL files are generated (original behavior)
    if ! $partial && $has_non_generated; then
        return 1
    fi

    # Resolve generated files with "ours"
    for file in "${generated_files[@]}"; do
        git checkout --ours "$file" 2>/dev/null && git add "$file" 2>/dev/null
    done

    info "Auto-resolved generated file conflicts: ${generated_files[*]}"

    # Return success only if no non-generated conflicts remain
    if $has_non_generated; then
        return 1
    fi
    return 0
}

llm_resolve_conflicts() {
    local source_branch="$1"
    local target_branch="$2"
    local conflicted_files="$3"

    info "Attempting LLM conflict resolution..."

    # Build prompt with all conflicted files
    local prompt="You are resolving git merge conflicts.
Source branch: $source_branch (being merged INTO target)
Target branch: $target_branch

Below are the files with conflict markers. Resolve each conflict by keeping both sides' changes where possible (integrate, don't pick one side). If changes are contradictory, prefer the source branch (the feature being merged).

Output ONLY the resolved files. For each file, output a header line exactly like:
--- FILE: <path> ---
followed by the COMPLETE file content (no conflict markers, no truncation).
Do not output anything else — no explanations, no markdown fences.

Conflicted files:
"

    while IFS= read -r file; do
        [[ -z "$file" ]] && continue
        prompt+="
--- FILE: $file ---
$(cat "$file")
"
    done <<< "$conflicted_files"

    # Call Claude with longer timeout for merge resolution
    local llm_output rc=0
    llm_output=$(export RUN_CLAUDE_TIMEOUT=300; echo "$prompt" | run_claude --model "$(resolve_model_id sonnet)" --max-turns 1) || rc=$?

    if [[ $rc -ne 0 || -z "$llm_output" ]]; then
        warn "LLM conflict resolution failed (exit code: $rc)"
        return 1
    fi

    # Parse output: extract each file block
    local current_file="" current_content="" files_resolved=0
    while IFS= read -r line; do
        if [[ "$line" =~ ^---\ FILE:\ (.+)\ ---$ ]]; then
            # Write previous file if any
            if [[ -n "$current_file" ]]; then
                printf '%s\n' "$current_content" > "$current_file"
                git checkout --ours "$current_file" 2>/dev/null || true
                printf '%s\n' "$current_content" > "$current_file"
                git add "$current_file"
                files_resolved=$((files_resolved + 1))
            fi
            current_file="${BASH_REMATCH[1]}"
            current_content=""
        elif [[ -n "$current_file" ]]; then
            if [[ -z "$current_content" ]]; then
                current_content="$line"
            else
                current_content+=$'\n'"$line"
            fi
        fi
    done <<< "$llm_output"

    # Write last file
    if [[ -n "$current_file" ]]; then
        printf '%s\n' "$current_content" > "$current_file"
        git checkout --ours "$current_file" 2>/dev/null || true
        printf '%s\n' "$current_content" > "$current_file"
        git add "$current_file"
        files_resolved=$((files_resolved + 1))
    fi

    if [[ $files_resolved -eq 0 ]]; then
        warn "LLM output did not contain any resolved files"
        return 1
    fi

    # Check if any conflicts remain
    local remaining_conflicts
    remaining_conflicts=$(git diff --name-only --diff-filter=U 2>/dev/null || true)
    if [[ -n "$remaining_conflicts" ]]; then
        warn "LLM resolved $files_resolved files but conflicts remain in: $remaining_conflicts"
        return 1
    fi

    info "LLM resolved $files_resolved conflicted file(s)"
    return 0
}

main() {
    local change_id=""
    local project_name=""
    local target_branch=""
    local squash=false
    local delete_branch=true
    local push_after=true
    local llm_resolve=false

    while [[ $# -gt 0 ]]; do
        case "$1" in
            -p|--project)
                project_name="$2"
                shift 2
                ;;
            --to)
                target_branch="$2"
                shift 2
                ;;
            --squash)
                squash=true
                shift
                ;;
            --no-delete)
                delete_branch=false
                shift
                ;;
            --no-push)
                push_after=false
                shift
                ;;
            --llm-resolve)
                llm_resolve=true
                shift
                ;;
            -h|--help)
                usage
                exit 0
                ;;
            -*)
                error "Unknown option: $1"
                usage
                exit 1
                ;;
            *)
                if [[ -z "$change_id" ]]; then
                    change_id="$1"
                else
                    error "Unexpected argument: $1"
                    usage
                    exit 1
                fi
                shift
                ;;
        esac
    done

    if [[ -z "$change_id" ]]; then
        error "Change ID required"
        usage
        exit 1
    fi

    # Resolve project
    local resolved_project
    resolved_project=$(resolve_project "$project_name") || exit 1

    local project_path
    project_path=$(get_project_path "$resolved_project")

    # Find existing worktree
    local wt_path
    wt_path=$(find_existing_worktree "$project_path" "$change_id")

    if [[ -z "$wt_path" || ! -d "$wt_path" ]]; then
        error "Worktree not found for: $change_id"
        exit 1
    fi

    # Get branch name from worktree
    local source_branch
    source_branch=$(git -C "$wt_path" rev-parse --abbrev-ref HEAD 2>/dev/null)

    if [[ -z "$source_branch" ]]; then
        error "Could not determine branch for worktree"
        exit 1
    fi

    # Determine target branch
    if [[ -z "$target_branch" ]]; then
        target_branch=$(find_default_branch "$project_path")
        if [[ -z "$target_branch" ]]; then
            error "Could not find default branch (main/master). Use --to <branch>"
            exit 1
        fi
    fi

    # Verify target branch exists
    if ! git -C "$project_path" show-ref --verify --quiet "refs/heads/$target_branch" 2>/dev/null; then
        error "Target branch '$target_branch' does not exist"
        exit 1
    fi

    # Check for uncommitted changes in worktree (auto-stash generated files)
    local changes
    changes=$(git -C "$wt_path" status --porcelain 2>/dev/null | grep -v "^?? \.zed/" | grep -v "^?? " || true)
    if [[ -n "$changes" ]]; then
        # Filter: are all changes in generated files?
        local non_generated=false
        while IFS= read -r line; do
            [[ -z "$line" ]] && continue
            local file="${line:3}"  # strip status prefix
            if ! is_generated_file "$file"; then
                non_generated=true
                break
            fi
        done <<< "$changes"

        if $non_generated; then
            error "Worktree has uncommitted changes. Commit or stash them first."
            echo ""
            echo "$changes"
            exit 1
        else
            # Auto-stash generated file changes
            git -C "$wt_path" stash --quiet 2>/dev/null || true
            info "Auto-stashed generated file changes in worktree"
        fi
    fi

    # Check for uncommitted changes in main repo (auto-stash generated files)
    local main_changes
    main_changes=$(git -C "$project_path" status --porcelain 2>/dev/null | grep -v "^?? " || true)
    if [[ -n "$main_changes" ]]; then
        local non_generated=false
        while IFS= read -r line; do
            [[ -z "$line" ]] && continue
            local file="${line:3}"
            if ! is_generated_file "$file"; then
                non_generated=true
                break
            fi
        done <<< "$main_changes"

        if $non_generated; then
            error "Main repo has uncommitted changes. Commit or stash them first."
            echo ""
            echo "$main_changes"
            echo ""
            echo "Run: cd $project_path && git stash"
            exit 1
        else
            git -C "$project_path" stash --quiet 2>/dev/null || true
            info "Auto-stashed generated file changes in main repo"
        fi
    fi

    info "Merging '$source_branch' into '$target_branch'..."
    echo "  Project: $resolved_project"
    echo "  Source: $source_branch"
    echo "  Target: $target_branch"
    if $squash; then
        echo "  Mode: squash"
    fi

    # Go to project root and checkout target branch
    cd "$project_path" || exit 1

    # Fetch latest
    git fetch origin "$target_branch" 2>/dev/null || true

    # Checkout target branch
    git checkout "$target_branch"
    if [[ $? -ne 0 ]]; then
        error "Failed to checkout '$target_branch'"
        exit 1
    fi

    # Pull latest
    git pull origin "$target_branch" 2>/dev/null || true

    # Merge (|| true to prevent set -e from killing on conflict)
    local merge_result=0
    if $squash; then
        git merge --squash "$source_branch" || merge_result=$?
        if [[ $merge_result -eq 0 ]]; then
            git commit -m "Squashed merge of '$source_branch'" || merge_result=$?
        fi
    else
        git merge "$source_branch" -m "Merge '$source_branch' into '$target_branch'" || merge_result=$?
    fi

    if [[ $merge_result -ne 0 ]]; then
        # Check if conflicts are only in auto-resolvable generated files
        local conflicted_files
        conflicted_files=$(git diff --name-only --diff-filter=U 2>/dev/null)

        # With --llm-resolve, resolve generated files even in mixed-conflict scenarios
        local partial_mode="false"
        $llm_resolve && partial_mode="true"

        if [[ -n "$conflicted_files" ]] && auto_resolve_generated_files "$conflicted_files" "$partial_mode"; then
            # All conflicts were in generated files and have been resolved
            git commit --no-edit 2>/dev/null
            merge_result=$?
        fi

        # Try LLM resolution for remaining conflicts
        if [[ $merge_result -ne 0 ]] && $llm_resolve; then
            conflicted_files=$(git diff --name-only --diff-filter=U 2>/dev/null)
            if [[ -n "$conflicted_files" ]]; then
                if llm_resolve_conflicts "$source_branch" "$target_branch" "$conflicted_files"; then
                    git commit --no-edit 2>/dev/null
                    merge_result=$?
                fi
            fi
        fi

        if [[ $merge_result -ne 0 ]]; then
            git merge --abort 2>/dev/null || true
            error "Merge failed! Resolve conflicts manually."
            echo ""
            echo "After resolving:"
            echo "  git add ."
            echo "  git commit"
            echo "  wt-close $change_id"
            exit 1
        fi
    fi

    success "Merge completed successfully"

    # Push merged target branch to origin
    if $push_after; then
        info "Pushing '$target_branch' to origin..."
        if git push origin "$target_branch"; then
            success "Pushed to origin/$target_branch"
        else
            warn "Failed to push to origin. Push manually: git push origin $target_branch"
        fi
    fi

    # Delete source branch if requested
    if $delete_branch; then
        echo ""
        info "Deleting source branch '$source_branch'..."
        if git branch -d "$source_branch" 2>/dev/null; then
            success "Branch '$source_branch' deleted"
        elif git branch -D "$source_branch" 2>/dev/null; then
            # Force delete if not fully merged (squash case)
            success "Branch '$source_branch' deleted (force)"
        else
            warn "Could not delete branch (still checked out in worktree)"
            echo "  Branch will be deleted when you run: wt-close $change_id"
        fi
    fi

    echo ""
    success "Done! Close the worktree with:"
    echo "  wt-close $change_id"
}

main "$@"
