#!/usr/bin/env bash
# wt-project - Manage project registry for wt-tools

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/wt-common.sh"

# Resolve wt-tools repo root (follow symlinks to find the real bin dir)
_wt_project_script="${BASH_SOURCE[0]}"
while [[ -L "$_wt_project_script" ]]; do
    _link=$(readlink "$_wt_project_script")
    if [[ "$_link" == /* ]]; then _wt_project_script="$_link"; else _wt_project_script="$(dirname "$_wt_project_script")/$_link"; fi
done
WT_TOOLS_ROOT="$(cd "$(dirname "$_wt_project_script")/.." && pwd)"

# Source deploy functions from lib/project/
source "$WT_TOOLS_ROOT/lib/project/deploy.sh"

# Get wt-tools version (git short hash or tag)
_get_wt_tools_version() {
    local version=""
    if [[ -d "$WT_TOOLS_ROOT/.git" ]] || git -C "$WT_TOOLS_ROOT" rev-parse --git-dir &>/dev/null; then
        # Prefer tag if on a tagged commit
        version=$(git -C "$WT_TOOLS_ROOT" describe --tags --exact-match 2>/dev/null || true)
        if [[ -z "$version" ]]; then
            version=$(git -C "$WT_TOOLS_ROOT" rev-parse --short HEAD 2>/dev/null || true)
        fi
    fi
    echo "${version:-unknown}"
}

# Find a Python 3 interpreter that has wt-project-base installed.
# Tries: miniconda, uv-managed, system python3 — returns first that works.
_wt_python() {
    local candidates=(
        "$HOME/miniconda3/bin/python"
        "$HOME/.local/share/uv/python/cpython-*/bin/python3"
        "$(command -v python3 2>/dev/null)"
        "$(command -v python 2>/dev/null)"
    )
    for py in "${candidates[@]}"; do
        [[ -z "$py" ]] && continue
        # Expand globs
        for resolved in $py; do
            [[ -x "$resolved" ]] || continue
            if "$resolved" -c "import wt_project_base" 2>/dev/null; then
                echo "$resolved"
                return 0
            fi
        done
    done
    # Fallback to plain python3 even if package not installed
    echo "python3"
}

# Known orchestration directives with defaults (for migration additive merge)
_KNOWN_DIRECTIVES='{"max_parallel":2,"default_model":"opus","time_limit":"","checkpoint_interval":5,"smoke_command":"","smoke_timeout":120,"smoke_blocking":true,"test_command":"","build_command":"","review_model":"","events_log":"","events_max_size":"","watchdog_timeout":"","watchdog_loop_threshold":"","max_tokens_per_change":"","context_pruning":true,"plan_approval":false,"model_routing":"off"}'

# Migrate consumer project on version change — additive only, never overwrites.
# Usage: _migrate_consumer <project-path> <old-version> <new-version>
_migrate_consumer() {
    local project_path="$1"
    local old_ver="$2"
    local new_ver="$3"
    local added_directives=0
    local created_files=0

    # 1. Additive directive merge for orchestration.yaml (check wt/ first)
    local orch_yaml="$project_path/wt/orchestration/config.yaml"
    if [[ ! -f "$orch_yaml" ]]; then
        orch_yaml="$project_path/.claude/orchestration.yaml"
    fi
    if [[ -f "$orch_yaml" ]]; then
        # Find directives in our known set that are missing from consumer's yaml
        local existing_keys
        existing_keys=$(grep -E '^[a-z_]+:' "$orch_yaml" 2>/dev/null | sed 's/:.*//' | tr '\n' '|' || true)

        if [[ -n "$existing_keys" ]]; then
            # Check each known directive
            local all_keys
            all_keys=$(echo "$_KNOWN_DIRECTIVES" | jq -r 'keys[]')
            while IFS= read -r key; do
                [[ -z "$key" ]] && continue
                if ! echo "$existing_keys" | grep -q "${key}|"; then
                    # Missing directive — add with comment
                    local default_val
                    default_val=$(echo "$_KNOWN_DIRECTIVES" | jq -r --arg k "$key" '.[$k] // ""')
                    if [[ "$DRY_RUN" == "true" ]]; then
                        info "  Would add directive: $key: $default_val"
                    else
                        echo "# $key: $default_val  # added by migration $old_ver → $new_ver" >> "$orch_yaml"
                    fi
                    added_directives=$((added_directives + 1))
                fi
            done <<< "$all_keys"
        fi
    fi

    # 2. Scaffold project-knowledge.yaml if missing
    local pk_file="$project_path/project-knowledge.yaml"
    if [[ ! -f "$pk_file" && -f "$WT_TOOLS_ROOT/templates/project-knowledge.yaml" ]]; then
        if [[ "$DRY_RUN" == "true" ]]; then
            info "  Would scaffold project-knowledge.yaml"
        else
            # Don't auto-create — just inform. Use init-knowledge for proper scaffolding
            info "  project-knowledge.yaml missing — run 'wt-project init-knowledge' to scaffold"
        fi
        created_files=$((created_files + 1))
    fi

    # 3. Deploy cross-cutting checklist if missing
    local checklist_dst="$project_path/.claude/rules/cross-cutting-checklist.md"
    if [[ ! -f "$checklist_dst" && -f "$WT_TOOLS_ROOT/templates/cross-cutting-checklist.md" ]]; then
        if [[ "$DRY_RUN" == "true" ]]; then
            info "  Would deploy cross-cutting-checklist.md"
        else
            mkdir -p "$(dirname "$checklist_dst")"
            cp "$WT_TOOLS_ROOT/templates/cross-cutting-checklist.md" "$checklist_dst"
        fi
        created_files=$((created_files + 1))
    fi

    # 4. Warn about unknown or deprecated directives
    if [[ -f "$orch_yaml" ]]; then
        local consumer_keys
        consumer_keys=$(grep -E '^[a-z_]+:' "$orch_yaml" 2>/dev/null | sed 's/:.*//' || true)
        local known_keys
        known_keys=$(echo "$_KNOWN_DIRECTIVES" | jq -r 'keys[]')
        # Also allow hook_* directives
        while IFS= read -r ckey; do
            [[ -z "$ckey" ]] && continue
            [[ "$ckey" == hook_* ]] && continue  # hook_* are valid
            if ! echo "$known_keys" | grep -qx "$ckey"; then
                warn "  Unknown directive in orchestration.yaml: $ckey"
            fi
        done <<< "$consumer_keys"
    fi

    if [[ $added_directives -gt 0 || $created_files -gt 0 ]]; then
        local verb="Updated"
        [[ "$DRY_RUN" == "true" ]] && verb="Would update"
        info "  $verb from $old_ver to $new_ver: added $added_directives directive(s), created $created_files file(s)"
    fi
}

# Deploy wt-tools hooks, commands, and skills to a project's .claude/ directory.
# Usage: deploy_wt_tools <project-path> [<extra-mcp-path> ...]
# extra-mcp-path: additional paths to register MCP for (e.g. current worktree)
deploy_wt_tools() {
    local project_path="$1"
    shift
    local claude_dir="$project_path/.claude"
    local _warnings=0

    # 0. Version tracking — store wt-tools version in consumer project
    local current_version
    current_version=$(_get_wt_tools_version)
    local version_file="$claude_dir/.wt-version"
    local old_version=""
    if [[ -f "$version_file" ]]; then
        old_version=$(cat "$version_file" 2>/dev/null || true)
    fi
    mkdir -p "$claude_dir"
    if [[ "$DRY_RUN" == "true" ]]; then
        if [[ -n "$old_version" && "$old_version" != "$current_version" ]]; then
            info "  Would update wt-tools: $old_version → $current_version"
            _migrate_consumer "$project_path" "$old_version" "$current_version"
        elif [[ -z "$old_version" ]]; then
            info "  Would write version: $current_version"
        fi
        return 0
    fi
    echo "$current_version" > "$version_file"
    if [[ -n "$old_version" && "$old_version" != "$current_version" ]]; then
        info "  wt-tools updated: $old_version → $current_version"
        _migrate_consumer "$project_path" "$old_version" "$current_version"
    fi

    # Deploy each subsystem via focused functions (from lib/project/deploy.sh)
    _deploy_hooks "$project_path" || ((_warnings++)) || true
    _deploy_commands "$project_path"
    _deploy_skills "$project_path"
    _deploy_memory "$project_path"
    scaffold_wt_directory "$project_path"
    _deploy_mcp "$project_path" "$@" || ((_warnings++)) || true

    return $(( _warnings > 0 ? 1 : 0 ))
}

# Register the unified wt-tools MCP server scoped to one or more project paths.
# _register_mcp_server and _cleanup_deprecated_memory_refs moved to lib/project/deploy.sh

# Resolve a project type name via Python entry points.
# Prints JSON with info, rules, and directives.
# Returns 1 if the project type is not found.
_resolve_project_type() {
    local type_name="$1"
    local py
    py=$(_wt_python)
    "$py" -c "
import json, sys
try:
    from importlib.metadata import entry_points
except ImportError:
    from importlib_metadata import entry_points

try:
    eps = entry_points(group='wt_tools.project_types')
except TypeError:
    eps = entry_points().get('wt_tools.project_types', [])

for ep in eps:
    if ep.name == '$type_name':
        cls = ep.load()
        pt = cls()
        info = pt.info
        rules = [{'id': r.id, 'description': r.description, 'check': r.check, 'severity': r.severity} for r in pt.get_verification_rules()]
        directives = [{'id': d.id, 'description': d.description, 'trigger': d.trigger, 'action': d.action} for d in pt.get_orchestration_directives()]
        print(json.dumps({'name': info.name, 'version': info.version, 'description': info.description, 'parent': info.parent, 'rules_count': len(rules), 'directives_count': len(directives)}))
        sys.exit(0)

print(json.dumps({'error': 'not_found'}), file=sys.stderr)
sys.exit(1)
" 2>/dev/null
}

# List available project types via Python entry points.
_list_project_types() {
    local py
    py=$(_wt_python)
    "$py" -c "
import sys
try:
    from importlib.metadata import entry_points
except ImportError:
    from importlib_metadata import entry_points

try:
    eps = entry_points(group='wt_tools.project_types')
except TypeError:
    eps = entry_points().get('wt_tools.project_types', [])

for ep in eps:
    try:
        cls = ep.load()
        pt = cls()
        info = pt.info
        print(f'  {ep.name:12s} — {info.description}')
    except Exception as e:
        print(f'  {ep.name:12s} — (failed to load: {e})', file=sys.stderr)
" 2>/dev/null
}

# Save project type to wt/plugins/project-type.yaml
_save_project_type() {
    local project_path="$1"
    local type_name="$2"
    local pt_file="$project_path/wt/plugins/project-type.yaml"

    # Validate project type exists
    local pt_info
    pt_info=$(_resolve_project_type "$type_name")
    if [[ $? -ne 0 || -z "$pt_info" ]]; then
        warn "  Project type '$type_name' not found. Available types:"
        _list_project_types
        return 1
    fi

    local version description parent rules_count directives_count
    version=$(echo "$pt_info" | python3 -c "import json,sys; print(json.load(sys.stdin).get('version',''))")
    description=$(echo "$pt_info" | python3 -c "import json,sys; print(json.load(sys.stdin).get('description',''))")
    parent=$(echo "$pt_info" | python3 -c "import json,sys; print(json.load(sys.stdin).get('parent','') or '')")
    rules_count=$(echo "$pt_info" | python3 -c "import json,sys; print(json.load(sys.stdin).get('rules_count',0))")
    directives_count=$(echo "$pt_info" | python3 -c "import json,sys; print(json.load(sys.stdin).get('directives_count',0))")

    mkdir -p "$(dirname "$pt_file")"
    cat > "$pt_file" << YAML
# Project type configuration — managed by wt-project init
# Change with: wt-project init --project-type <type>
type: $type_name
version: $version
description: "$description"
$([ -n "$parent" ] && echo "parent: $parent" || true)

# Stats: ${rules_count} verification rules, ${directives_count} orchestration directives
# Rules and directives are loaded dynamically from the installed package.
# Use 'wt-project-base resolve --project-dir .' to see the merged final set.

# ── Project Customizations ──────────────────────────────────────────
# Add, disable, or override rules and directives below.
# These sections are yours — wt-project init will not overwrite them.

# Add custom verification rules (same format as package rules):
# custom_rules:
#   - id: my-custom-rule
#     description: "Description of what this rule checks"
#     check: pattern-absence    # check type
#     severity: warning         # error, warning, info
#     config:
#       pattern: "src/**/*.ts"
#       forbidden: "some-pattern"

# Disable package rules that don't apply to this project:
# disabled_rules:
#   - ghost-button-text
#   - todo-tracking

# Override config of existing rules:
# rule_overrides:
#   file-size-limit:
#     config:
#       max_lines: 600

# Add custom orchestration directives:
# custom_directives:
#   - id: run-custom-lint
#     description: "Run custom linter after changes"
#     trigger: 'change-modifies("src/**")'
#     action: post-merge
#     config: { command: "pnpm lint:custom" }

# Disable package directives:
# disabled_directives:
#   - install-deps-python

# For personal (non-shared) overrides, create .local-overrides.yaml
# in this directory — it uses the same format and is gitignored.
YAML

    success "  Project type set to '$type_name' ($rules_count rules, $directives_count directives)"

    # Also register in projects.json — look up by path, not basename
    if [[ -f "$CONFIG_FILE" ]]; then
        local abs_path
        abs_path=$(cd "$project_path" && pwd)
        local tmp
        tmp=$(mktemp)
        jq --arg path "$abs_path" --arg pt "$type_name" \
            '(.projects | to_entries[] | select(.value.path == $path)) as $e |
             if $e then .projects[$e.key].project_type = $pt else . end' \
            "$CONFIG_FILE" > "$tmp" && mv "$tmp" "$CONFIG_FILE"
    fi
}

# Scaffold wt/ directory structure in a project.
# Creates all standard subdirectories. Idempotent — safe to re-run.
scaffold_wt_directory() {
    local project_path="$1"
    local wt_dir="$project_path/wt"

    mkdir -p \
        "$wt_dir/orchestration/runs" \
        "$wt_dir/orchestration/plans" \
        "$wt_dir/orchestration/specs/archive" \
        "$wt_dir/knowledge/patterns" \
        "$wt_dir/knowledge/lessons" \
        "$wt_dir/requirements" \
        "$wt_dir/plugins" \
        "$wt_dir/.work"

    # Add wt/.work/ to .gitignore if not already present
    local gitignore="$project_path/.gitignore"
    if [[ -f "$gitignore" ]]; then
        if ! grep -qx 'wt/.work/' "$gitignore" 2>/dev/null; then
            echo 'wt/.work/' >> "$gitignore"
        fi
    else
        echo 'wt/.work/' > "$gitignore"
    fi

    success "  Scaffolded wt/ directory structure"

    # Detect legacy files and print migration suggestions
    local found_legacy=false
    local legacy_msgs=()
    if [[ -f "$project_path/.claude/orchestration.yaml" ]]; then
        legacy_msgs+=("    .claude/orchestration.yaml → wt/orchestration/config.yaml")
        found_legacy=true
    fi
    if [[ -f "$project_path/project-knowledge.yaml" ]]; then
        legacy_msgs+=("    project-knowledge.yaml → wt/knowledge/project-knowledge.yaml")
        found_legacy=true
    fi
    if [[ -d "$project_path/docs/orchestration-runs" ]]; then
        legacy_msgs+=("    docs/orchestration-runs/ → wt/orchestration/runs/")
        found_legacy=true
    fi

    if $found_legacy; then
        echo ""
        info "  Found legacy files that can be migrated:"
        for msg in "${legacy_msgs[@]}"; do
            echo "$msg"
        done
        echo ""
        info "  Run 'wt-project migrate' to move them."
    fi
}

usage() {
    cat <<EOF
Usage: wt-project <command> [options]

Commands:
  init [--name <name>]    Register current git repo as a project
  init-knowledge          Scaffold project-knowledge.yaml from project scan
  migrate                 Migrate legacy files to wt/ directory structure
  list                    List all registered projects
  list-types              List available project types
  remove <name>           Remove a project from registry
  default <name>          Set default project

Options:
  --name <name>           Custom project name (default: directory name)
  --project-type <type>   Set project type (e.g., base, web)
  --dry-run               Show what would change without modifying files
  -h, --help              Show this help

Examples:
  cd /path/to/myproject && wt-project init
  wt-project init --name myproj --project-type web
  wt-project init --dry-run
  wt-project init-knowledge
  wt-project list-types
  wt-project list
  wt-project default myproj
  wt-project remove myproj
EOF
}

DRY_RUN=false

cmd_init() {
    local name=""
    local project_type=""

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --name)
                name="$2"
                shift 2
                ;;
            --project-type)
                project_type="$2"
                shift 2
                ;;
            --dry-run)
                DRY_RUN=true
                shift
                ;;
            *)
                error "Unknown option: $1"
                usage
                exit 1
                ;;
        esac
    done

    # Check if we're in a git repo
    if ! is_git_repo; then
        error "Current directory is not a git repository"
        echo "Please run this command from within a git repository."
        exit 1
    fi

    local git_root
    git_root=$(get_git_root)

    # Use directory name if no name specified
    if [[ -z "$name" ]]; then
        name=$(basename "$git_root")
    fi

    ensure_config

    # Check if we're in a worktree (not the main repo)
    local current_dir
    current_dir=$(git rev-parse --show-toplevel 2>/dev/null)
    local in_worktree=false
    if [[ "$current_dir" != "$git_root" ]]; then
        in_worktree=true
    fi

    # Check if project name already exists
    local existing_path
    existing_path=$(get_project_path "$name")
    if [[ -n "$existing_path" ]]; then
        if [[ "$existing_path" == "$git_root" ]]; then
            if $in_worktree; then
                info "Project '$name' already registered. Updating wt-tools deployment..."
                echo "  Main repo: $git_root"
            else
                info "Project '$name' already registered. Updating wt-tools deployment..."
            fi
            # Skip registration, proceed to deploy
        else
            error "Project name '$name' is already used for: $existing_path"
            echo "Use --name to specify a different name."
            exit 1
        fi
    else
        # Add project to registry
        local timestamp
        timestamp=$(date -u +"%Y-%m-%dT%H:%M:%SZ")
        local tmp
        tmp=$(mktemp)
        jq --arg name "$name" --arg path "$git_root" --arg ts "$timestamp" \
            '.projects[$name] = {"path": $path, "addedAt": $ts}' "$CONFIG_FILE" > "$tmp" && mv "$tmp" "$CONFIG_FILE"

        # Set as default if no default exists
        local current_default
        current_default=$(get_default_project)
        if [[ -z "$current_default" || "$current_default" == "null" ]]; then
            json_set "$CONFIG_FILE" ".default" "\"$name\""
            success "Project '$name' registered and set as default"
        else
            success "Project '$name' registered"
        fi
        echo "  Path: $git_root"
    fi

    # Deploy wt-tools to main repo
    local _deploy_warnings=0
    echo ""
    info "Deploying wt-tools to $git_root..."
    deploy_wt_tools "$git_root" || ((_deploy_warnings++))

    # Save project type if specified
    if [[ -n "$project_type" ]]; then
        _save_project_type "$git_root" "$project_type"
    fi

    # If called from a worktree, also deploy to the worktree's own .claude/ dir
    # and register MCP for the worktree path scope
    if $in_worktree; then
        echo ""
        info "Deploying wt-tools to worktree $current_dir..."
        deploy_wt_tools "$current_dir" || ((_deploy_warnings++))
    fi
    echo ""
    if [[ $_deploy_warnings -gt 0 ]]; then
        warn "wt-tools deployment complete for '$name' (with warnings — check output above)"
    else
        success "wt-tools deployment complete for '$name'"
    fi

    # Run health audit if wt-audit is available
    if command -v wt-audit &>/dev/null; then
        echo ""
        (cd "$git_root" && wt-audit scan --condensed 2>/dev/null) || true
    fi
}

cmd_list() {
    ensure_config

    local projects
    projects=$(jq -r '.projects | keys[]' "$CONFIG_FILE" 2>/dev/null)

    if [[ -z "$projects" ]]; then
        info "No projects registered."
        echo "Run 'wt-project init' inside a git repository to register it."
        exit 0
    fi

    local default_project
    default_project=$(get_default_project)

    echo "Registered projects:"
    echo ""

    while IFS= read -r name; do
        local path
        path=$(get_project_path "$name")
        if [[ "$name" == "$default_project" ]]; then
            echo -e "  ${GREEN}* $name${NC} -> $path"
        else
            echo "    $name -> $path"
        fi

        # Show worktrees for this project
        list_project_worktrees_brief "$name" "$path"
    done <<< "$projects"

    echo ""
    if [[ -n "$default_project" && "$default_project" != "null" ]]; then
        echo "Default: $default_project"
    fi
}

list_project_worktrees_brief() {
    local project_name="$1"
    local project_path="$2"

    if [[ ! -d "$project_path" ]]; then
        return
    fi

    # Get worktrees from git
    local worktrees
    worktrees=$(git -C "$project_path" worktree list --porcelain 2>/dev/null)

    if [[ -z "$worktrees" ]]; then
        return
    fi

    local current_path=""

    while IFS= read -r line; do
        if [[ "$line" =~ ^worktree\ (.+)$ ]]; then
            current_path="${BASH_REMATCH[1]}"
        elif [[ -z "$line" && -n "$current_path" ]]; then
            # Skip main repo, only show worktrees
            if [[ "$current_path" != "$project_path" ]]; then
                local wt_name
                wt_name=$(basename "$current_path")
                echo -e "      ${BLUE}└─ $wt_name${NC} -> $current_path"
            fi
            current_path=""
        fi
    done <<< "$worktrees"

    # Process last entry
    if [[ -n "$current_path" && "$current_path" != "$project_path" ]]; then
        local wt_name
        wt_name=$(basename "$current_path")
        echo -e "      ${BLUE}└─ $wt_name${NC} -> $current_path"
    fi
}

cmd_remove() {
    local name="$1"

    if [[ -z "$name" ]]; then
        error "Project name required"
        echo "Usage: wt-project remove <name>"
        exit 1
    fi

    ensure_config

    local path
    path=$(get_project_path "$name")
    if [[ -z "$path" ]]; then
        error "Project '$name' not found"
        exit 1
    fi

    # Remove from registry
    local tmp
    tmp=$(mktemp)
    jq --arg name "$name" 'del(.projects[$name])' "$CONFIG_FILE" > "$tmp" && mv "$tmp" "$CONFIG_FILE"

    # Clear default if this was the default
    local current_default
    current_default=$(get_default_project)
    if [[ "$current_default" == "$name" ]]; then
        json_set "$CONFIG_FILE" ".default" "null"
        warn "Cleared default project (was '$name')"
    fi

    success "Project '$name' removed from registry"
    echo "Note: Existing worktrees were not deleted."
}

cmd_default() {
    local name="$1"

    if [[ -z "$name" ]]; then
        error "Project name required"
        echo "Usage: wt-project default <name>"
        exit 1
    fi

    ensure_config

    local path
    path=$(get_project_path "$name")
    if [[ -z "$path" ]]; then
        error "Project '$name' not found"
        echo "Run 'wt-project list' to see available projects."
        exit 1
    fi

    json_set "$CONFIG_FILE" ".default" "\"$name\""
    success "Default project set to '$name'"
}

# Migrate legacy files to wt/ directory structure.
# Uses git mv when in a git repo, plain mv otherwise.
cmd_migrate() {
    if ! is_git_repo; then
        error "Current directory is not a git repository"
        exit 1
    fi

    local git_root
    git_root=$(get_git_root)
    local use_git=true
    local migrated=0

    # Helper: move file/dir with git mv or plain mv
    _migrate_move() {
        local src="$1"
        local dst="$2"
        mkdir -p "$(dirname "$dst")"
        if $use_git; then
            git -C "$git_root" mv "$src" "$dst" 2>/dev/null || mv "$src" "$dst"
        else
            mv "$src" "$dst"
        fi
    }

    # 1. orchestration.yaml → wt/orchestration/config.yaml
    local orch_src="$git_root/.claude/orchestration.yaml"
    local orch_dst="$git_root/wt/orchestration/config.yaml"
    if [[ -f "$orch_src" && ! -f "$orch_dst" ]]; then
        _migrate_move "$orch_src" "$orch_dst"
        success "  Migrated .claude/orchestration.yaml → wt/orchestration/config.yaml"
        migrated=$((migrated + 1))
    fi

    # 2. project-knowledge.yaml → wt/knowledge/project-knowledge.yaml
    local pk_src="$git_root/project-knowledge.yaml"
    local pk_dst="$git_root/wt/knowledge/project-knowledge.yaml"
    if [[ -f "$pk_src" && ! -f "$pk_dst" ]]; then
        _migrate_move "$pk_src" "$pk_dst"
        success "  Migrated project-knowledge.yaml → wt/knowledge/project-knowledge.yaml"
        migrated=$((migrated + 1))
    fi

    # 3. docs/orchestration-runs/* → wt/orchestration/runs/
    local runs_src="$git_root/docs/orchestration-runs"
    local runs_dst="$git_root/wt/orchestration/runs"
    if [[ -d "$runs_src" ]] && ls "$runs_src"/*.md &>/dev/null; then
        mkdir -p "$runs_dst"
        for f in "$runs_src"/*.md; do
            local fname
            fname=$(basename "$f")
            if [[ ! -f "$runs_dst/$fname" ]]; then
                _migrate_move "$f" "$runs_dst/$fname"
            fi
        done
        # Remove empty source dir
        rmdir "$runs_src" 2>/dev/null || true
        success "  Migrated docs/orchestration-runs/ → wt/orchestration/runs/"
        migrated=$((migrated + 1))
    fi

    if [[ $migrated -eq 0 ]]; then
        info "No legacy files found to migrate."
    else
        success "Migrated $migrated item(s). Review with 'git status' and commit."
    fi
}

cmd_init_knowledge() {
    if ! is_git_repo; then
        error "Current directory is not a git repository"
        exit 1
    fi

    local git_root
    git_root=$(get_git_root)
    # Prefer wt/knowledge/ when wt/ exists, fallback to project root
    local pk_file="$git_root/project-knowledge.yaml"
    if [[ -d "$git_root/wt/knowledge" ]]; then
        pk_file="$git_root/wt/knowledge/project-knowledge.yaml"
    fi
    local template="$WT_TOOLS_ROOT/templates/project-knowledge.yaml"

    if [[ -f "$pk_file" ]]; then
        info "project-knowledge.yaml already exists at $pk_file"
        echo "Edit it manually to add cross-cutting files and features."
        return 0
    fi
    # Also check legacy location if targeting wt/
    if [[ "$pk_file" == *"/wt/knowledge/"* && -f "$git_root/project-knowledge.yaml" ]]; then
        info "project-knowledge.yaml exists at project root. Run 'wt-project migrate' to move it."
        return 0
    fi

    if [[ ! -f "$template" ]]; then
        error "Template not found: $template"
        exit 1
    fi

    # Scan project for common cross-cutting patterns
    local cross_cutting_entries=""
    local found=0

    # i18n / translation files
    local i18n_files
    i18n_files=$(find "$git_root" -maxdepth 5 \( -path "*/i18n/*.json" -o -path "*/locales/*.json" -o -path "*/lang/*.json" \) -not -path "*/node_modules/*" 2>/dev/null | head -5 || true)
    if [[ -n "$i18n_files" ]]; then
        while IFS= read -r f; do
            [[ -z "$f" ]] && continue
            local rel="${f#$git_root/}"
            cross_cutting_entries+="  - path: $rel"$'\n'"    description: Translation file"$'\n'
            found=$((found + 1))
        done <<< "$i18n_files"
    fi

    # Sidebar / navigation components
    local sidebar
    sidebar=$(find "$git_root" -maxdepth 5 \( -iname "*sidebar*" -o -iname "*navigation*" -o -iname "*nav-menu*" \) -not -path "*/node_modules/*" 2>/dev/null | grep -E '\.(tsx?|jsx?|vue|svelte)$' || true)
    if [[ -n "$sidebar" ]]; then
        while IFS= read -r f; do
            [[ -z "$f" ]] && continue
            local rel="${f#$git_root/}"
            cross_cutting_entries+="  - path: $rel"$'\n'"    description: Navigation component"$'\n'
            found=$((found + 1))
        done <<< "$sidebar"
    fi

    # Route definitions
    local routes
    routes=$(find "$git_root" -maxdepth 5 \( -iname "routes.*" -o -iname "router.*" \) -not -path "*/node_modules/*" 2>/dev/null | grep -E '\.(tsx?|jsx?|py|rb)$' || true)
    if [[ -n "$routes" ]]; then
        while IFS= read -r f; do
            [[ -z "$f" ]] && continue
            local rel="${f#$git_root/}"
            cross_cutting_entries+="  - path: $rel"$'\n'"    description: Route definitions"$'\n'
            found=$((found + 1))
        done <<< "$routes"
    fi

    # Database schema files
    local schemas
    schemas=$(find "$git_root" -maxdepth 4 \( -iname "schema.prisma" -o -iname "schema.rb" \) -not -path "*/node_modules/*" 2>/dev/null | head -3 || true)
    if [[ -n "$schemas" ]]; then
        while IFS= read -r f; do
            [[ -z "$f" ]] && continue
            local rel="${f#$git_root/}"
            cross_cutting_entries+="  - path: $rel"$'\n'"    description: Database schema"$'\n'
            found=$((found + 1))
        done <<< "$schemas"
    fi

    # Copy template
    cp "$template" "$pk_file"

    # If we found cross-cutting files, inject them
    if [[ -n "$cross_cutting_entries" && "$found" -gt 0 ]]; then
        # Replace the commented examples under cross_cutting_files with actual entries
        local tmp
        tmp=$(mktemp)
        awk -v entries="$cross_cutting_entries" '
            /^cross_cutting_files:/ { print; found=1; next }
            found && /^[^ #]/ { printf "%s", entries; found=0 }
            found && /^  #/ { next }
            { print }
            END { if (found) printf "%s", entries }
        ' "$pk_file" > "$tmp" && mv "$tmp" "$pk_file"
    fi

    success "Created $pk_file"
    if [[ "$found" -gt 0 ]]; then
        info "Auto-detected $found cross-cutting file(s) — review and edit the file"
    else
        info "No cross-cutting files auto-detected — edit manually to add entries"
    fi

    # Deploy cross-cutting checklist if not exists
    local checklist_src="$WT_TOOLS_ROOT/templates/cross-cutting-checklist.md"
    local checklist_dst="$git_root/.claude/rules/cross-cutting-checklist.md"
    if [[ -f "$checklist_src" && ! -f "$checklist_dst" ]]; then
        mkdir -p "$(dirname "$checklist_dst")"
        cp "$checklist_src" "$checklist_dst"
        success "Deployed cross-cutting-checklist.md to .claude/rules/"
    fi
}

# Main
if [[ $# -eq 0 ]]; then
    usage
    exit 1
fi

case "$1" in
    init)
        shift
        cmd_init "$@"
        ;;
    init-knowledge)
        shift
        cmd_init_knowledge "$@"
        ;;
    migrate)
        shift
        cmd_migrate "$@"
        ;;
    list|ls)
        cmd_list
        ;;
    list-types)
        echo "Available project types:"
        _list_project_types
        ;;
    remove|rm)
        shift
        cmd_remove "$@"
        ;;
    default)
        shift
        cmd_default "$@"
        ;;
    -h|--help|help)
        usage
        ;;
    *)
        error "Unknown command: $1"
        usage
        exit 1
        ;;
esac
