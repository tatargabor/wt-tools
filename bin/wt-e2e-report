#!/usr/bin/env bash
# wt-e2e-report — Generate E2E test report from orchestration state
#
# Reads orchestration-state.json, generates a markdown report with:
# - Run summary (duration, total tokens, changes)
# - Per-change table (name, status, tokens, duration)
# - Timeline of state transitions
# - Directives used
# - Comparison with previous report if available
# - Optional Playwright screenshots
#
# Usage:
#   wt-e2e-report                          # Use current directory
#   wt-e2e-report --project-dir /path/to   # Specify project dir
#   wt-e2e-report --no-screenshots         # Skip screenshot capture

set -euo pipefail

# ── Args ──

PROJECT_DIR="."
SCREENSHOTS=true

while [[ $# -gt 0 ]]; do
    case "$1" in
        --project-dir)
            PROJECT_DIR="$2"
            shift 2
            ;;
        --project-dir=*)
            PROJECT_DIR="${1#*=}"
            shift
            ;;
        --no-screenshots)
            SCREENSHOTS=false
            shift
            ;;
        --screenshots)
            SCREENSHOTS=true
            shift
            ;;
        *)
            echo "Usage: wt-e2e-report [--project-dir <path>] [--no-screenshots]" >&2
            exit 1
            ;;
    esac
done

cd "$PROJECT_DIR"

# ── Validation ──

STATE_FILE="orchestration-state.json"
REPORT_FILE="e2e-report.md"
PREV_REPORT="e2e-report-prev.md"

if [[ ! -f "$STATE_FILE" ]]; then
    echo "Error: $STATE_FILE not found in $PROJECT_DIR" >&2
    exit 1
fi

# ── Rotate previous report ──

if [[ -f "$REPORT_FILE" ]]; then
    mv "$REPORT_FILE" "$PREV_REPORT"
    echo "Rotated existing report to $PREV_REPORT"
fi

# ── Screenshot capture ──

if [[ "$SCREENSHOTS" == "true" ]]; then
    echo "Capturing screenshots..."
    mkdir -p e2e-screenshots

    # Build the app first
    if pnpm build 2>/dev/null; then
        # Start production server in background
        pnpm start &
        SERVER_PID=$!

        # Wait for server to be ready (poll health endpoint)
        RETRIES=30
        while [[ $RETRIES -gt 0 ]]; do
            if curl -s http://localhost:3000/api/health | grep -q '"ok"' 2>/dev/null; then
                break
            fi
            sleep 1
            ((RETRIES--)) || true
        done

        if [[ $RETRIES -gt 0 ]]; then
            # Copy capture script from wt-tools source
            local SCRIPT_DIR
            SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
            local CAPTURE_SRC="$SCRIPT_DIR/tests/e2e/capture-screenshots.ts"
            local CAPTURE_DST="tests/e2e/capture-screenshots.ts"
            if [[ -f "$CAPTURE_SRC" ]]; then
                mkdir -p "$(dirname "$CAPTURE_DST")"
                cp "$CAPTURE_SRC" "$CAPTURE_DST"
                pnpm exec playwright test "$CAPTURE_DST" 2>/dev/null || echo "Screenshot capture had errors (non-fatal)"
                rm -f "$CAPTURE_DST"
            else
                echo "Warning: $CAPTURE_SRC not found, skipping screenshots"
            fi
        else
            echo "Warning: server did not become ready, skipping screenshots"
        fi

        # Kill server
        kill "$SERVER_PID" 2>/dev/null || true
        wait "$SERVER_PID" 2>/dev/null || true
    else
        echo "Warning: pnpm build failed, skipping screenshots"
    fi
fi

# ── Extract data from state.json ──

status=$(jq -r '.status // "unknown"' "$STATE_FILE")
started_at=$(jq -r '.started_at // "unknown"' "$STATE_FILE")
completed_at=$(jq -r '.completed_at // .last_updated // "unknown"' "$STATE_FILE")
total_tokens=$(jq -r '.total_tokens // 0' "$STATE_FILE")
changes_count=$(jq -r '.changes | length' "$STATE_FILE")
completed_count=$(jq -r '[.changes[] | select(.status == "completed" or .status == "merged")] | length' "$STATE_FILE")
failed_count=$(jq -r '[.changes[] | select(.status == "failed" or .status == "stuck")] | length' "$STATE_FILE")

# Calculate duration
if [[ "$started_at" != "unknown" && "$completed_at" != "unknown" ]]; then
    start_epoch=$(date -d "$started_at" +%s 2>/dev/null || echo "0")
    end_epoch=$(date -d "$completed_at" +%s 2>/dev/null || echo "0")
    if [[ "$start_epoch" -gt 0 && "$end_epoch" -gt 0 ]]; then
        duration_secs=$((end_epoch - start_epoch))
        duration_min=$((duration_secs / 60))
        duration_str="${duration_min}m"
    else
        duration_str="unknown"
    fi
else
    duration_str="unknown"
fi

# Format tokens
format_tokens() {
    local n="$1"
    if [[ "$n" -ge 1000000 ]]; then
        echo "$((n / 1000000))M"
    elif [[ "$n" -ge 1000 ]]; then
        echo "$((n / 1000))K"
    else
        echo "$n"
    fi
}

total_tokens_fmt=$(format_tokens "$total_tokens")

# ── Generate report ──

{
    echo "# E2E Report"
    echo ""
    echo "Generated: $(date -Iseconds)"
    echo ""
    echo "## Run Summary"
    echo ""
    echo "| Metric | Value |"
    echo "|---|---|"
    echo "| Status | $status |"
    echo "| Duration | $duration_str |"
    echo "| Total Tokens | $total_tokens_fmt ($total_tokens) |"
    echo "| Changes | $changes_count total, $completed_count completed, $failed_count failed |"
    echo "| Started | $started_at |"
    echo "| Completed | $completed_at |"
    echo ""

    # Per-change table
    echo "## Per-Change Results"
    echo ""
    echo "| Change | Status | Tokens | Duration | Iterations |"
    echo "|---|---|---|---|---|"

    jq -r '.changes[] | [
        .name,
        .status,
        (.tokens // 0 | tostring),
        (if .started_at and .completed_at then
            ((.completed_at | split("T")[0]) + " " + (.completed_at | split("T")[1] | split(".")[0] | split("+")[0]))
        else "—" end),
        (.iterations // 0 | tostring)
    ] | "| " + join(" | ") + " |"' "$STATE_FILE" 2>/dev/null || echo "| (no change data) | — | — | — | — |"

    echo ""

    # Timeline
    echo "## Timeline"
    echo ""
    echo '```'
    jq -r '.changes[] | "\(.started_at // "?") → \(.name): \(.status)"' "$STATE_FILE" 2>/dev/null | sort || echo "(no timeline data)"
    echo '```'
    echo ""

    # Directives
    echo "## Directives Used"
    echo ""
    if jq -e '.directives' "$STATE_FILE" >/dev/null 2>&1; then
        jq -r '.directives | to_entries[] | "- **\(.key):** \(.value)"' "$STATE_FILE" 2>/dev/null || echo "- (none)"
    elif jq -e '.config' "$STATE_FILE" >/dev/null 2>&1; then
        jq -r '.config | to_entries[] | "- **\(.key):** \(.value)"' "$STATE_FILE" 2>/dev/null || echo "- (none)"
    else
        echo "- (none found in state)"
    fi
    echo ""

    # Comparison with previous
    if [[ -f "$PREV_REPORT" ]]; then
        echo "## Comparison with Previous Run"
        echo ""
        prev_tokens=$(grep -oP 'Total Tokens \| \S+ \((\d+)\)' "$PREV_REPORT" 2>/dev/null | grep -oP '\d+' | tail -1 || echo "0")
        if [[ -n "$prev_tokens" && "$prev_tokens" -gt 0 ]]; then
            diff_tokens=$((total_tokens - prev_tokens))
            if [[ $diff_tokens -ge 0 ]]; then
                echo "- Token change: +$(format_tokens "$diff_tokens") (prev: $(format_tokens "$prev_tokens"), now: $total_tokens_fmt)"
            else
                abs_diff=$((-diff_tokens))
                echo "- Token change: -$(format_tokens "$abs_diff") (prev: $(format_tokens "$prev_tokens"), now: $total_tokens_fmt)"
            fi
        else
            echo "- Previous report exists but could not parse token total"
        fi
        echo ""
    fi

    # Screenshots section (placeholder — filled by screenshot step)
    if [[ "$SCREENSHOTS" == "true" ]]; then
        echo "## Screenshots"
        echo ""
        if [[ -d "e2e-screenshots" ]] && ls e2e-screenshots/*.png &>/dev/null; then
            for img in e2e-screenshots/*.png; do
                name=$(basename "$img" .png)
                echo "### $name"
                echo "![$name]($img)"
                echo ""
            done
        else
            echo "No screenshots captured."
        fi
        echo ""
    fi

} > "$REPORT_FILE"

echo "Report generated: $REPORT_FILE"
echo "  Status: $status | Duration: $duration_str | Tokens: $total_tokens_fmt | Changes: $completed_count/$changes_count"
exit 0
