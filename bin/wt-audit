#!/usr/bin/env bash
# wt-audit — Project health scanner with evidence-based guidance
#
# Usage: wt-audit scan [--json] [--condensed]
#        wt-audit help
#
# Scans 6 project health dimensions and reports evidence, delta, and guidance.
# Does NOT generate files — provides source pointers for the LLM to act on.

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/wt-common.sh"

# Resolve wt-tools root (follow symlinks)
_audit_script="${BASH_SOURCE[0]}"
while [[ -L "$_audit_script" ]]; do
    _link=$(readlink "$_audit_script")
    if [[ "$_link" == /* ]]; then _audit_script="$_link"; else _audit_script="$(dirname "$_audit_script")/$_link"; fi
done
WT_TOOLS_ROOT="$(cd "$(dirname "$_audit_script")/.." && pwd)"

# Source helpers
source "$WT_TOOLS_ROOT/lib/audit/helpers.sh"

# Source stack detection
source "$WT_TOOLS_ROOT/lib/audit/detect-stack.sh"

# Source all check functions
for check_file in "$WT_TOOLS_ROOT"/lib/audit/check-*.sh; do
    [[ -f "$check_file" ]] && source "$check_file"
done

usage() {
    cat <<EOF
Usage: wt-audit <command> [options]

Commands:
  scan [--json] [--condensed]   Scan project health (6 dimensions)
  help                          Show this help

Options:
  --json        Output structured JSON instead of human-readable text
  --condensed   Show only the summary line (for wt-project init)

Examples:
  wt-audit scan                 # Human-readable report
  wt-audit scan --json          # Machine-readable JSON
  wt-audit scan --condensed     # Summary line only
EOF
}

cmd_scan() {
    local json_mode=false
    local condensed_mode=false

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --json)      json_mode=true; shift ;;
            --condensed) condensed_mode=true; shift ;;
            *)           error "Unknown option: $1"; usage; exit 1 ;;
        esac
    done

    # Detect project root
    local project_path=""
    local project_name=""

    if is_git_repo; then
        project_path=$(get_git_root)
        project_name=$(basename "$project_path")
    else
        error "Not in a git repository. Run from a project directory."
        exit 1
    fi

    # Run stack detection
    detect_stack "$project_path"

    # Run all checks
    check_claude_config "$project_path"
    check_design_docs "$project_path"
    check_openspec_config "$project_path"
    check_code_signals "$project_path"
    check_claude_md "$project_path"
    check_gitignore "$project_path"

    # Output
    if $json_mode; then
        build_json "$project_name"
    elif $condensed_mode; then
        print_condensed_summary
    else
        echo ""
        echo -e "  ${MAGENTA}PROJECT HEALTH REPORT — ${project_name}${NC}"
        echo "  $(printf '═%.0s' {1..50})"

        local -a all_dimensions=("claude_config" "design_docs" "openspec_config" "code_signals" "claude_md" "gitignore")
        local -a dim_titles=("Claude Code Config" "Design Documentation" "OpenSpec Config" "Code Quality Signals" "CLAUDE.md Structure" "Gitignore Coverage")

        for i in "${!all_dimensions[@]}"; do
            # Only print dimension if it has checks
            local has_checks=false
            for entry in "${AUDIT_CHECKS[@]}"; do
                [[ "${entry%%|*}" == "${all_dimensions[$i]}" ]] && has_checks=true && break
            done
            $has_checks || continue

            print_dimension_header "${dim_titles[$i]}"
            print_dimension_checks "${all_dimensions[$i]}"
            print_dimension_guidance "${all_dimensions[$i]}"
        done

        print_summary
        echo ""
    fi
}

# Main
if [[ $# -eq 0 ]]; then
    usage
    exit 1
fi

case "$1" in
    scan)
        shift
        cmd_scan "$@"
        ;;
    -h|--help|help)
        usage
        ;;
    *)
        error "Unknown command: $1"
        usage
        exit 1
        ;;
esac
